<div class="section-card">
    <div class="flex-between mb-20">
        <h2>멤버십 혜택 설정</h2>
        <button type="submit" form="settingsForm" class="btn btn-primary">변경사항 저장</button>
    </div>

    <form id="settingsForm" action="/admin/membership/settings" method="POST" class="admin-form">
        <% settings.forEach(setting => { %>
            <div class="membership-setting-block mb-30 p-20 bg-light rounded shadow-sm">
                <h3><i class="fas fa-tag"></i> <%= setting.type === 'prepaid' ? '선불 충전형' : '정기 구독형' %></h3>
                <input type="hidden" name="settings[<%= setting.id %>][id]" value="<%= setting.id %>">
                
                <div class="form-grid mt-15">
                    <div class="form-group">
                        <label>할인율 (%)</label>
                        <input type="number" step="0.1" name="settings[<%= setting.id %>][discount_rate]" value="<%= setting.discount_rate %>" class="admin-input">
                    </div>
                    <% if (setting.type === 'prepaid') { %>
                        <div class="form-group">
                            <label>추가 적립률 (%)</label>
                            <input type="number" step="0.1" name="settings[<%= setting.id %>][reward_rate]" value="<%= setting.reward_rate %>" class="admin-input">
                        </div>
                    <% } else { %>
                        <div class="form-group">
                            <label>월 회비 (원)</label>
                            <input type="number" name="settings[<%= setting.id %>][monthly_fee]" value="<%= setting.monthly_fee %>" class="admin-input">
                        </div>
                    <% } %>
                </div>
                
                <div class="form-group mt-15">
                    <label>혜택 설명 (고객 노출용)</label>
                    <textarea name="settings[<%= setting.id %>][benefit_description]" class="admin-input" rows="3"><%= setting.benefit_description %></textarea>
                </div>
            </div>
        <% }) %>
    </form>
</div>

<style>
.membership-setting-block h3 { margin: 0; font-size: 1.1rem; color: var(--dark); border-bottom: 2px solid #eee; padding-bottom: 10px; }
.bg-light { background-color: #f8f9fa; }
.p-20 { padding: 20px; }
</style>
