<div class="section-card">
    <div class="flex-between mb-20">
        <h2>파일 관리</h2>
        <span class="muted-text">업로드한 파일과 URL에서 내려받은 파일을 한곳에서 관리합니다.</span>
    </div>

    <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
    <% } %>
    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="file-actions-grid">
        <form action="/admin/files/upload" method="POST" enctype="multipart/form-data" class="file-panel">
            <h3><i class="fas fa-upload"></i> 파일 업로드</h3>
            <div class="form-group">
                <label for="managed_file">파일 선택</label>
                <input type="file" id="managed_file" name="managed_file" required>
            </div>
            <div class="form-group">
                <label for="upload_note">메모</label>
                <input type="text" id="upload_note" name="note" placeholder="예: 거래처 계약서, 상품 이미지 원본">
            </div>
            <button type="submit" class="btn btn-primary"><i class="fas fa-upload"></i> 업로드</button>
        </form>

        <form action="/admin/files/download-url" method="POST" class="file-panel">
            <h3><i class="fas fa-cloud-download-alt"></i> URL 다운로드</h3>
            <div class="form-group">
                <label for="file_url">파일 URL</label>
                <input type="url" id="file_url" name="file_url" placeholder="https://example.com/file.pdf" required>
            </div>
            <div class="form-group">
                <label for="download_note">메모</label>
                <input type="text" id="download_note" name="note" placeholder="예: 공급사 자료, 참고 이미지">
            </div>
            <button type="submit" class="btn btn-secondary"><i class="fas fa-download"></i> 다운로드</button>
        </form>
    </div>
</div>

<div class="section-card">
    <div class="flex-between mb-20">
        <h2>보관 파일</h2>
        <span class="muted-text"><%= files.length %>개</span>
    </div>

    <table class="admin-table">
        <thead>
            <tr>
                <th>파일명</th>
                <th>출처</th>
                <th>크기</th>
                <th>메모</th>
                <th>등록일</th>
                <th>관리</th>
            </tr>
        </thead>
        <tbody>
            <% if (files && files.length > 0) { %>
                <% files.forEach(file => { %>
                    <tr>
                        <td>
                            <strong><%= file.original_name %></strong><br>
                            <small><%= file.mime_type || '알 수 없음' %></small>
                        </td>
                        <td>
                            <% if (file.source_url) { %>
                                <a href="<%= file.source_url %>" target="_blank" rel="noopener" class="table-link">URL</a>
                            <% } else { %>
                                직접 업로드
                            <% } %>
                        </td>
                        <td><%= (Number(file.size_bytes || 0) / 1024).toLocaleString('ko-KR', { maximumFractionDigits: 1 }) %> KB</td>
                        <td><%= file.note || '-' %></td>
                        <td><%= file.created_at ? new Date(file.created_at).toLocaleString('ko-KR') : '-' %></td>
                        <td>
                            <a href="/admin/files/<%= file.id %>/download" class="btn-icon" title="다운로드"><i class="fas fa-download"></i></a>
                            <form action="/admin/files/<%= file.id %>/delete" method="POST" class="inline-form" onsubmit="return confirm('이 파일을 삭제할까요?')">
                                <button type="submit" class="btn-icon button-link text-red" title="삭제"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="6" class="text-center">등록된 파일이 없습니다.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>
