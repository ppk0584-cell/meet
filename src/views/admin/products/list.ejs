<div class="section-card">
    <div class="flex-between mb-20">
        <h2>전체 상품 목록</h2>
        <a href="/admin/products/add" class="btn btn-primary"><i class="fas fa-plus"></i> 신규 상품 등록</a>
    </div>

    <table class="admin-table">
        <thead>
            <tr>
                <th>카테고리</th>
                <th>상품명/부위</th>
                <th>등급</th>
                <th>100g당 가격</th>
                <th>현재 재고</th>
                <th>도축일/이력번호</th>
                <th>관리</th>
            </tr>
        </thead>
        <tbody>
            <% if (products && products.length > 0) { %>
                <% products.forEach(product => { %>
                    <tr>
                        <td><%= product.category %></td>
                        <td>
                            <strong><%= product.name %></strong><br>
                            <small><%= product.part %></small>
                        </td>
                        <td><%= product.grade %></td>
                        <td><%= product.price_per_100g.toLocaleString() %>원</td>
                        <td><span class="status-badge <%= product.stock_quantity > 10 ? 'stock' : 'out' %>"><%= product.stock_quantity %>kg</span></td>
                        <td>
                            <%= product.slaughter_date %><br>
                            <small><%= product.trace_number %></small>
                        </td>
                        <td>
                            <a href="/admin/products/<%= product.id %>/recipes" class="btn-icon" title="레시피 관리"><i class="fas fa-utensils"></i></a>
                            <a href="/admin/products/edit/<%= product.id %>" class="btn-icon"><i class="fas fa-edit"></i></a>
                            <a href="/admin/products/delete/<%= product.id %>" class="btn-icon text-red" onclick="return confirm('정말 삭제하시겠습니까?')"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="7" class="text-center">등록된 상품이 없습니다.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>
