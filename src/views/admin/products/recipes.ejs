<div class="section-card">
    <div class="flex-between mb-20">
        <div>
            <h2><%= product.name %> 레시피 관리</h2>
            <p class="muted-text">소비자 화면에는 링크 주소 대신 영상보기 버튼으로 노출됩니다.</p>
        </div>
        <a href="/admin/products" class="btn btn-secondary">상품 목록</a>
    </div>

    <form action="/admin/products/<%= product.id %>/recipes" method="POST" class="admin-form recipe-form">
        <div class="form-grid">
            <div class="form-group">
                <label for="recipe_title">레시피명</label>
                <input type="text" id="recipe_title" name="recipe_title" required placeholder="예: 집에서 굽는 등심 스테이크">
            </div>
            <div class="form-group">
                <label for="video_url">영상 링크</label>
                <input type="url" id="video_url" name="video_url" placeholder="https://youtube.com/...">
            </div>
            <div class="form-group">
                <label for="plating_image_url">플래팅 사진 URL</label>
                <input type="url" id="plating_image_url" name="plating_image_url" placeholder="https://...">
            </div>
            <div class="form-group">
                <label for="sort_order">노출 순서</label>
                <input type="number" id="sort_order" name="sort_order" value="0">
            </div>
            <div class="form-group">
                <label>
                    <input type="checkbox" name="is_active" value="1" checked>
                    소비자에게 노출
                </label>
            </div>
        </div>
        <div class="form-group">
            <label for="ingredients">재료</label>
            <textarea id="ingredients" name="ingredients" rows="5" placeholder="고기 300g&#10;소금 약간&#10;후추 약간"></textarea>
        </div>
        <div class="form-group">
            <label for="cooking_steps">조리방법</label>
            <textarea id="cooking_steps" name="cooking_steps" rows="7" placeholder="1. 고기를 실온에 둡니다.&#10;2. 팬을 예열합니다."></textarea>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fas fa-plus"></i> 레시피 추가</button>
        </div>
    </form>
</div>

<div class="section-card">
    <h2>등록된 레시피</h2>
    <table class="admin-table">
        <thead>
            <tr>
                <th>순서</th>
                <th>레시피명</th>
                <th>플래팅 사진</th>
                <th>영상</th>
                <th>상태</th>
                <th>관리</th>
            </tr>
        </thead>
        <tbody>
            <% if (recipes.length) { %>
                <% recipes.forEach(recipe => { %>
                    <tr>
                        <td><%= recipe.sort_order %></td>
                        <td><strong><%= recipe.recipe_title %></strong></td>
                        <td><%= recipe.plating_image_url ? '등록됨' : '없음' %></td>
                        <td><%= recipe.video_url ? '등록됨' : '없음' %></td>
                        <td><span class="status-badge <%= recipe.is_active ? 'stock' : 'out' %>"><%= recipe.is_active ? '노출' : '숨김' %></span></td>
                        <td>
                            <form action="/admin/products/<%= product.id %>/recipes/<%= recipe.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('이 레시피를 삭제하시겠습니까?')">
                                <button type="submit" class="btn-icon text-red" style="border:0;background:none;cursor:pointer;"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="6" class="text-center">등록된 레시피가 없습니다.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

<style>
.muted-text {
    margin: 4px 0 0;
    color: #777;
}
.recipe-form {
    border-top: 1px solid #eee;
    padding-top: 18px;
}
</style>
