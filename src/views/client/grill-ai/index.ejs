<section class="grill-ai-page">
    <div class="grill-hero">
        <span class="eyebrow">LIVE GRILL ASSISTANT</span>
        <h1>고기가 익는 순간을 보고 뒤집을 때를 알려드립니다.</h1>
        <p>입력값 없이 1초 단위 프레임을 임시 분석합니다. 사진은 서버에 저장하지 않고, 고기 하단 테두리와 측면 익힘을 중심으로 판단합니다.</p>
    </div>

    <div class="grill-workspace">
        <div class="grill-camera-card">
            <div class="grill-stage">
                <video id="grillVideo" autoplay playsinline muted></video>
                <canvas id="grillCanvas"></canvas>
                <div class="scan-area edge-focus" aria-hidden="true">
                    <span></span>
                    <b class="edge-left"></b>
                    <b class="edge-right"></b>
                    <b class="edge-bottom"></b>
                </div>
                <div id="flipOverlay" class="flip-overlay" hidden>
                    <strong id="flipOverlayText">지금 뒤집으세요</strong>
                    <span id="flipOverlayReason">표면 갈변이 충분합니다.</span>
                </div>
                <div id="grillPlaceholder" class="grill-placeholder">
                    <i class="fas fa-fire-burner"></i>
                    <strong>카메라를 그릴 위 고기에 맞춰주세요.</strong>
                    <span>시작하면 자동으로 프레임을 읽고 뒤집기 타이밍을 안내합니다.</span>
                </div>
            </div>

            <div class="grill-actions">
                <button type="button" id="startGrillAi" class="primary-action">
                    <i class="fas fa-play"></i> AI 굽기 시작
                </button>
                <button type="button" id="stopGrillAi" class="secondary-action" disabled>
                    <i class="fas fa-stop"></i> 정지
                </button>
                <button type="button" id="toggleVoice" class="secondary-action is-on">
                    <i class="fas fa-volume-high"></i> 음성 켜짐
                </button>
            </div>
        </div>

        <aside class="grill-status-panel">
            <span class="result-label">실시간 판단</span>
            <h2 id="grillStatusTitle">대기 중</h2>
            <div id="grillMessage" class="grill-message">카메라를 시작하면 1초 단위 시각 신호와 4초 단위 AI 확인을 함께 사용합니다.</div>

            <div class="signal-grid" aria-label="분석 신호">
                <div>
                    <span>갈변</span>
                    <meter id="brownMeter" min="0" max="100" value="0"></meter>
                </div>
                <div>
                    <span>붉은기</span>
                    <meter id="redMeter" min="0" max="100" value="0"></meter>
                </div>
                <div>
                    <span>탄화</span>
                    <meter id="charMeter" min="0" max="100" value="0"></meter>
                </div>
                <div>
                    <span>AI 확신</span>
                    <meter id="confidenceMeter" min="0" max="100" value="0"></meter>
                </div>
            </div>

            <ol class="grill-flow">
                <li>하단 박스 안에 고기의 아래쪽 테두리와 옆면이 보이게 맞춥니다.</li>
                <li>1초마다 프레임을 임시 분석하고 서버에 사진을 저장하지 않습니다.</li>
                <li>측면 갈변과 가장자리 육즙 신호가 맞으면 “지금 뒤집으세요”를 안내합니다.</li>
            </ol>

            <p class="grill-safety">AI 안내는 사진 기반 참고용입니다. 두꺼운 고기, 닭고기, 분쇄육은 내부 온도계를 함께 사용해 주세요.</p>
        </aside>
    </div>
</section>

<script>
const grillVideo = document.getElementById('grillVideo');
const grillCanvas = document.getElementById('grillCanvas');
const grillPlaceholder = document.getElementById('grillPlaceholder');
const startGrillAi = document.getElementById('startGrillAi');
const stopGrillAi = document.getElementById('stopGrillAi');
const toggleVoice = document.getElementById('toggleVoice');
const flipOverlay = document.getElementById('flipOverlay');
const flipOverlayText = document.getElementById('flipOverlayText');
const flipOverlayReason = document.getElementById('flipOverlayReason');
const grillStatusTitle = document.getElementById('grillStatusTitle');
const grillMessage = document.getElementById('grillMessage');
const brownMeter = document.getElementById('brownMeter');
const redMeter = document.getElementById('redMeter');
const charMeter = document.getElementById('charMeter');
const confidenceMeter = document.getElementById('confidenceMeter');

let grillStream = null;
let localTimer = null;
let aiTimer = null;
let voiceEnabled = true;
let lastSpokenAt = 0;
let lastLocalStatus = 'wait';
let aiInFlight = false;

function setPanel(status, message, confidence = 0) {
    const labels = { wait: '조금 더 기다리세요', soon: '곧 뒤집을 준비', now: '지금 뒤집으세요', over: '너무 익었습니다' };
    grillStatusTitle.textContent = labels[status] || '분석 중';
    grillStatusTitle.dataset.status = status;
    grillMessage.textContent = message;
    confidenceMeter.value = Math.round(confidence * 100);
}

function speak(message) {
    if (!voiceEnabled || !window.speechSynthesis) return;
    const now = Date.now();
    if (now - lastSpokenAt < 9000) return;
    lastSpokenAt = now;
    window.speechSynthesis.cancel();
    const utterance = new SpeechSynthesisUtterance(message);
    utterance.lang = 'ko-KR';
    utterance.rate = 1;
    window.speechSynthesis.speak(utterance);
}

function showFlipOverlay(status, message, reason) {
    if (status === 'wait') {
        flipOverlay.hidden = true;
        return;
    }
    flipOverlay.hidden = false;
    flipOverlay.dataset.status = status;
    flipOverlayText.textContent = message;
    flipOverlayReason.textContent = reason || '';
    if (status === 'now' || status === 'over') speak(message);
}

function captureFrameBlob(quality = 0.78) {
    if (!grillVideo.videoWidth) return Promise.resolve(null);
    const sourceWidth = grillVideo.videoWidth;
    const sourceHeight = grillVideo.videoHeight;
    const cropX = Math.floor(sourceWidth * 0.12);
    const cropY = Math.floor(sourceHeight * 0.42);
    const cropWidth = Math.floor(sourceWidth * 0.76);
    const cropHeight = Math.floor(sourceHeight * 0.5);
    grillCanvas.width = cropWidth;
    grillCanvas.height = cropHeight;
    const context = grillCanvas.getContext('2d', { willReadFrequently: true });
    context.drawImage(grillVideo, cropX, cropY, cropWidth, cropHeight, 0, 0, cropWidth, cropHeight);
    return new Promise(resolve => grillCanvas.toBlob(resolve, 'image/jpeg', quality));
}

function analyzeLocalFrame() {
    if (!grillVideo.videoWidth) return;
    grillCanvas.width = 240;
    grillCanvas.height = 180;
    const context = grillCanvas.getContext('2d', { willReadFrequently: true });
    context.drawImage(grillVideo, 0, 0, grillCanvas.width, grillCanvas.height);
    const sx = Math.floor(grillCanvas.width * 0.12);
    const sy = Math.floor(grillCanvas.height * 0.42);
    const sw = Math.floor(grillCanvas.width * 0.76);
    const sh = Math.floor(grillCanvas.height * 0.5);
    const { data } = context.getImageData(sx, sy, sw, sh);
    let brown = 0;
    let red = 0;
    let char = 0;
    let bright = 0;
    const total = data.length / 4;
    for (let i = 0; i < data.length; i += 4) {
        const r = data[i];
        const g = data[i + 1];
        const b = data[i + 2];
        const avg = (r + g + b) / 3;
        const pixelIndex = i / 4;
        const x = pixelIndex % sw;
        const y = Math.floor(pixelIndex / sw);
        const sideOrBottomWeight = x < sw * 0.18 || x > sw * 0.82 || y > sh * 0.58 ? 1.55 : 1;
        if (r > 85 && r < 190 && g > 42 && g < 125 && b < 95 && r > g * 1.18) brown += sideOrBottomWeight;
        if (r > 120 && g < 95 && b < 90 && r > g * 1.35) red += sideOrBottomWeight;
        if (avg < 48 && r < 72 && g < 72 && b < 72) char += sideOrBottomWeight;
        if (avg > 185) bright += 1;
    }
    const brownScore = Math.min(100, Math.round((brown / total) * 260));
    const redScore = Math.min(100, Math.round((red / total) * 240));
    const charScore = Math.min(100, Math.round((char / total) * 320));
    brownMeter.value = brownScore;
    redMeter.value = redScore;
    charMeter.value = charScore;

    let status = 'wait';
    let message = '표면 변화를 보고 있습니다.';
    if (charScore > 32 && brownScore > 28) {
        status = 'over';
        message = '탄화 신호가 강합니다. 바로 확인하세요.';
    } else if (brownScore > 48 && redScore < 38) {
        status = 'now';
        message = '지금 뒤집으세요.';
    } else if (brownScore > 34 || (brownScore > 24 && redScore < 52)) {
        status = 'soon';
        message = '곧 뒤집을 준비를 해주세요.';
    }
    lastLocalStatus = status;
    setPanel(status, message, status === 'now' ? 0.62 : status === 'soon' ? 0.45 : 0.2);
    showFlipOverlay(status, message, '고기 하단 테두리와 측면의 갈변/탄화 신호 기준입니다.');
}

async function askAiForFrame() {
    if (aiInFlight) return;
    aiInFlight = true;
    const blob = await captureFrameBlob();
    if (!blob) {
        aiInFlight = false;
        return;
    }
    const formData = new FormData();
    formData.append('grillFrame', blob, 'grill-frame.jpg');
    try {
        const response = await fetch('/grill-ai/analyze-frame', {
            method: 'POST',
            body: formData
        });
        const data = await response.json();
        if (!response.ok) throw new Error(data.error || 'AI 확인 실패');
        const aiStatus = data.flip_status || 'wait';
        const priority = { wait: 0, soon: 1, now: 2, over: 3 };
        const status = priority[aiStatus] >= priority[lastLocalStatus] ? aiStatus : lastLocalStatus;
        const message = status === aiStatus ? data.message : (status === 'now' ? '지금 뒤집으세요.' : '곧 뒤집을 준비를 해주세요.');
        setPanel(status, message, data.confidence || 0);
        showFlipOverlay(status, message, data.visual_reason || 'AI가 표면 상태를 확인했습니다.');
    } catch (error) {
        grillMessage.textContent = 'AI 확인이 지연되어 화면 색 변화 기준으로 안내 중입니다.';
    } finally {
        aiInFlight = false;
    }
}

async function startAssistant() {
    try {
        grillStream = await navigator.mediaDevices.getUserMedia({
            video: {
                facingMode: { ideal: 'environment' },
                width: { ideal: 1280 },
                height: { ideal: 720 }
            },
            audio: false
        });
        grillVideo.srcObject = grillStream;
        grillVideo.style.display = 'block';
        grillPlaceholder.style.display = 'none';
        startGrillAi.disabled = true;
        stopGrillAi.disabled = false;
        setPanel('wait', '분석을 시작했습니다. 고기 하단 테두리와 측면이 박스 안에 보이게 맞춰주세요.');
        localTimer = window.setInterval(analyzeLocalFrame, 1000);
        aiTimer = window.setInterval(askAiForFrame, 1000);
        window.setTimeout(askAiForFrame, 1000);
    } catch (error) {
        setPanel('wait', '카메라를 열 수 없습니다. 브라우저 권한을 확인해주세요.');
    }
}

function stopAssistant() {
    window.clearInterval(localTimer);
    window.clearInterval(aiTimer);
    localTimer = null;
    aiTimer = null;
    if (grillStream) grillStream.getTracks().forEach(track => track.stop());
    grillStream = null;
    grillVideo.srcObject = null;
    grillVideo.style.display = 'none';
    grillPlaceholder.style.display = 'grid';
    flipOverlay.hidden = true;
    startGrillAi.disabled = false;
    stopGrillAi.disabled = true;
    setPanel('wait', '정지했습니다. 다시 시작하면 실시간 분석을 재개합니다.');
}

startGrillAi.addEventListener('click', startAssistant);
stopGrillAi.addEventListener('click', stopAssistant);
toggleVoice.addEventListener('click', () => {
    voiceEnabled = !voiceEnabled;
    toggleVoice.classList.toggle('is-on', voiceEnabled);
    toggleVoice.innerHTML = voiceEnabled
        ? '<i class="fas fa-volume-high"></i> 음성 켜짐'
        : '<i class="fas fa-volume-xmark"></i> 음성 꺼짐';
});
</script>

