    opacity: 0.48;
    cursor: not-allowed;
}
#analyzePhoto {
    grid-column: 1 / -1;
}
.fallback-upload {
    min-height: 46px;
    border-radius: 999px;
    border: 1px solid var(--line);
    margin-top: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--green);
    font-weight: 800;
    cursor: pointer;
}
.fallback-upload input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
}
.camera-guide {
    display: grid;
    gap: 8px;
    margin-top: 14px;
}
.camera-guide div {
    display: flex;
    gap: 10px;
    color: var(--muted);
    line-height: 1.4;
}
.camera-guide i {
    color: var(--gold);
    margin-top: 3px;
}
.analysis-panel {
    padding: 26px;
}
.result-label {
    color: var(--gold);
    font-size: 0.78rem;
    font-weight: 800;
}
.analysis-panel h2 {
    margin: 10px 0 12px;
    font-size: 1.8rem;
}
.analysis-status {
    background: var(--paper);
    border-radius: 8px;
