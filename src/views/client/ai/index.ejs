    max-width: none;
    margin: 10px 0 12px;
    font-size: clamp(2rem, 4vw, 3.7rem);
    line-height: 1.04;
    white-space: nowrap;
}
.camera-hero p {
    max-width: 640px;
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
}
.live-camera-shell {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 16px;
    align-items: start;
}
.live-camera-card,
.analysis-panel {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: 0 16px 42px rgba(66, 42, 18, 0.07);
}
