    padding: 16px;
}
.camera-stage {
    min-height: 430px;
    border-radius: 8px;
    border: 1px dashed #cbbd9a;
    overflow: hidden;
    background: #fffdf8;
    display: grid;
    place-items: center;
    position: relative;
}
.camera-stage video,
.camera-stage img {
    width: 100%;
    height: 100%;
    min-height: 430px;
    object-fit: cover;
    display: none;
}
#captureCanvas {
    display: none;
}
.camera-placeholder {
    text-align: center;
    padding: 24px;
}
.camera-placeholder i {
    width: 74px;
    height: 74px;
    border-radius: 50%;
    background: var(--primary);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.85rem;
    margin-bottom: 18px;
}
.camera-placeholder strong,
.camera-placeholder span {
    display: block;
}
.camera-placeholder strong {
    font-size: 1.35rem;
}
.camera-placeholder span {
    color: var(--muted);
    margin-top: 8px;
}
.live-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 12px;
}
.live-actions button {
    min-height: 50px;
    border-radius: 999px;
    font: inherit;
    font-weight: 800;
    cursor: pointer;
}
.secondary-action {
    background: #fff;
    border: 1px solid var(--line);
    color: var(--green);
}
.primary-action {
    background: var(--primary);
