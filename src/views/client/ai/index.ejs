<section class="camera-ai-page">
    <div class="camera-hero">
        <span class="eyebrow">LIVE CAMERA CHECK</span>
        <h1>촬영하면 같은 화면에서 바로 분석합니다.</h1>
        <p>사진을 서버에 파일로 저장하지 않고, 촬영한 한 장을 분석 요청에만 사용합니다.</p>
    </div>

    <div class="live-camera-shell">
        <div class="live-camera-card">
            <div class="camera-stage">
                <video id="cameraVideo" autoplay playsinline muted></video>
                <canvas id="captureCanvas"></canvas>
                <img id="capturedPreview" alt="촬영한 고기 사진">
                <div id="cameraPlaceholder" class="camera-placeholder">
                    <i class="fas fa-camera"></i>
                    <strong>카메라 시작</strong>
                    <span>고기를 화면에 맞춘 뒤 촬영하세요.</span>
                </div>
            </div>

            <div class="live-actions">
                <button type="button" id="startCamera" class="secondary-action">
                    <i class="fas fa-video"></i> 카메라 켜기
                </button>
                <button type="button" id="capturePhoto" class="primary-action" disabled>
                    <i class="fas fa-camera"></i> 촬영하기
                </button>
                <button type="button" id="analyzePhoto" class="primary-action" disabled>
                    <i class="fas fa-wand-magic-sparkles"></i> 바로 분석
                </button>
            </div>

            <label class="fallback-upload">
                <input type="file" id="fallbackFile" accept="image/*" capture="environment">
                <span><i class="fas fa-image"></i> 카메라가 안 열리면 사진 선택</span>
            </label>

            <div class="camera-guide">
                <div><i class="fas fa-sun"></i><span>밝은 곳에서 촬영</span></div>
                <div><i class="fas fa-ruler-combined"></i><span>고기가 화면의 대부분을 차지하게</span></div>
                <div><i class="fas fa-droplet"></i><span>포장 비닐 반사를 줄이기</span></div>
            </div>
        </div>

        <aside class="analysis-panel live-result">
            <span class="result-label">AI 분석 결과</span>
            <h2 id="resultTitle">촬영 후 결과가 여기에 표시됩니다.</h2>
            <div id="analysisStatus" class="analysis-status">카메라를 켜고 고기 사진을 촬영해 주세요.</div>
            <div id="analysisContent" class="analysis-content"></div>
            <p class="analysis-note">사진상 보이는 특징만 분석합니다. 냄새, 실제 등급, 위생 상태는 매장 확인이 필요합니다.</p>
        </aside>
    </div>
</section>

<script>
const video = document.getElementById('cameraVideo');
const canvas = document.getElementById('captureCanvas');
const preview = document.getElementById('capturedPreview');
const placeholder = document.getElementById('cameraPlaceholder');
const startButton = document.getElementById('startCamera');
const captureButton = document.getElementById('capturePhoto');
const analyzeButton = document.getElementById('analyzePhoto');
const fallbackFile = document.getElementById('fallbackFile');
const statusBox = document.getElementById('analysisStatus');
const contentBox = document.getElementById('analysisContent');
const resultTitle = document.getElementById('resultTitle');

let cameraStream = null;
let capturedBlob = null;

function setStatus(message) {
    statusBox.textContent = message;
    statusBox.style.display = 'block';
}

function showResult(text) {
    resultTitle.textContent = '사진 기준 품질 체크';
    statusBox.style.display = 'none';
    contentBox.innerHTML = text.replace(/\n/g, '<br>');
    contentBox.classList.add('is-visible');
}

async function startCamera() {
    try {
        cameraStream = await navigator.mediaDevices.getUserMedia({
            video: { facingMode: { ideal: 'environment' } },
            audio: false
        });
        video.srcObject = cameraStream;
        video.style.display = 'block';
        preview.style.display = 'none';
        placeholder.style.display = 'none';
        captureButton.disabled = false;
        analyzeButton.disabled = true;
        capturedBlob = null;
        setStatus('카메라가 켜졌습니다. 고기를 화면에 맞춘 뒤 촬영하세요.');
    } catch (error) {
        setStatus('카메라를 열 수 없습니다. 아래 사진 선택 버튼을 사용해 주세요.');
    }
}

function capturePhoto() {
    if (!video.videoWidth) return;
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    canvas.getContext('2d').drawImage(video, 0, 0, canvas.width, canvas.height);
    canvas.toBlob((blob) => {
        capturedBlob = blob;
        preview.src = URL.createObjectURL(blob);
        preview.style.display = 'block';
        video.style.display = 'none';
        analyzeButton.disabled = false;
        setStatus('촬영 완료. 바로 분석 버튼을 눌러주세요.');
    }, 'image/jpeg', 0.9);
}

async function analyzePhoto() {
    if (!capturedBlob) {
        setStatus('먼저 사진을 촬영해 주세요.');
        return;
    }

    const formData = new FormData();
    formData.append('meatImage', capturedBlob, 'camera-capture.jpg');

    analyzeButton.disabled = true;
    setStatus('분석 중입니다. 잠시만 기다려 주세요.');
    contentBox.classList.remove('is-visible');

    try {
        const response = await fetch('/ai-analysis/analyze-camera', {
            method: 'POST',
            body: formData
        });
        const data = await response.json();
        if (!response.ok) throw new Error(data.error || '분석 실패');
        showResult(data.result);
    } catch (error) {
        setStatus(error.message || '분석 중 오류가 발생했습니다.');
    } finally {
        analyzeButton.disabled = false;
    }
}

fallbackFile.addEventListener('change', () => {
    const file = fallbackFile.files && fallbackFile.files[0];
    if (!file) return;
    capturedBlob = file;
    preview.src = URL.createObjectURL(file);
    preview.style.display = 'block';
    video.style.display = 'none';
    placeholder.style.display = 'none';
    analyzeButton.disabled = false;
    setStatus('사진 선택 완료. 바로 분석 버튼을 눌러주세요.');
});

startButton.addEventListener('click', startCamera);
captureButton.addEventListener('click', capturePhoto);
analyzeButton.addEventListener('click', analyzePhoto);
</script>

<style>
.camera-ai-page {
    background: #f8f3ea;
    padding-bottom: 70px;
}
.camera-hero {
    max-width: 1180px;
    margin: 0 auto;
    padding: 42px 20px 22px;
}
