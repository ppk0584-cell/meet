    margin: 16px 0 0;
}
@media (max-width: 860px) {
    .camera-hero {
        padding: 34px 16px 18px;
    }
    .camera-hero h1 {
        font-size: 2.25rem;
        white-space: normal;
    }
    .live-camera-shell {
        grid-template-columns: 1fr;
        padding: 0 16px;
    }
    .live-camera-card,
    .analysis-panel {
        padding: 16px;
    }
    .camera-stage,
    .camera-stage video,
    .camera-stage img {
        min-height: 360px;
    }
}
</style>
