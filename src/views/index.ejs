<script>
const scenes = [
    {
        title: '고민하는 순간부터 쉽게',
        text: '메뉴 선택부터 필요한 상품과 레시피까지 한 번에 이어집니다.'
    },
    {
        title: '오늘 손질한 신선함',
        text: '고기, 야채, 필요한 준비물까지 목적에 맞게 고릅니다.'
    },
    {
        title: '가족이 맛있게 먹는 한 끼',
        text: '무엇을 해 먹을지 고민하지 않도록 메뉴 선택을 돕습니다.'
    },
    {
        title: '손님상에서도 빛나는 요리',
        text: '잘 고른 고기와 레시피로 초대한 사람에게 실력을 보여줄 수 있습니다.'
    },
    {
        title: '캠핑장까지 편하게',
        text: '캠핑용 세트는 주문만 하면 수령지와 날짜를 확인해 준비합니다.'
    }
];

const sceneImages = [...document.querySelectorAll('.home-scene')];
const sceneTitle = document.getElementById('sceneTitle');
const sceneText = document.getElementById('sceneText');
const thoughtBubble = document.getElementById('thoughtBubble');
let sceneIndex = 0;

window.setInterval(() => {
    sceneImages[sceneIndex].classList.remove('is-active');
    sceneIndex = (sceneIndex + 1) % sceneImages.length;
    sceneImages[sceneIndex].classList.add('is-active');
    sceneTitle.textContent = scenes[sceneIndex].title;
    sceneText.textContent = scenes[sceneIndex].text;
    if (thoughtBubble) thoughtBubble.hidden = sceneIndex !== 0;
}, 3600);
</script>

